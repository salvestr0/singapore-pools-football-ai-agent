# Copy this file to .env and fill in your real values
# Never commit .env — it is in .gitignore

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
FOOTBALL_DATA_API_KEY=your_football_data_org_api_key_here
GEMINI_API_KEY=your_google_gemini_api_key_here

# Real-time lineups — free tier at https://dashboard.api-football.com
API_FOOTBALL_KEY=your_api_football_key_here

# Pinnacle sharp lines (CLV) — free tier at https://the-odds-api.com
ODDS_API_KEY=your_the_odds_api_key_here
